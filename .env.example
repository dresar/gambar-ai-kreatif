# Salin ke .env (lokal) atau isi di Vercel → Settings → Environment Variables
# Mode: development (npm run dev) | production (Vercel set NODE_ENV=production otomatis)

# --- Wajib ---
DATABASE_URL=postgresql://USER:PASS@HOST/neondb?sslmode=require
# JWT production: minimal 32 karakter. Generate: node scripts/gen-jwt-secret.mjs
JWT_SECRET=ganti-dengan-secret-panjang-minimal-32-karakter-production

# --- Frontend ---
# Lokal: http://localhost:5000  |  Production (Vercel sama origin): kosongkan
VITE_API_URL=

# --- AI upstream (chat / analisis gambar) ---
AI_BASE_URL=https://one.apprentice.cyou/api/v1
AI_MODEL=gemini-2.5-flash
AI_API_KEY=your-bearer-token
AI_REQUEST_TIMEOUT_MS=120000
AI_RETRY_ATTEMPTS=3

# --- Production CORS (Vercel) ---
# URL depan yang boleh memanggil API (tanpa slash akhir). Contoh: https://app-anda.vercel.app
FRONTEND_URL=
# Tambahan asal, pisah koma (opsional)
# CORS_ORIGINS=https://domain1.com,https://domain2.com
