# ========== MODE ==========
# NODE_ENV — hanya untuk proses Node (API). Lokal biasanya tidak perlu set.
#   development = npm run dev:api   |   production = Vercel otomatis saat deploy
#
# Frontend (Vite): saat npm run build → otomatis PRODUCTION (tanpa tombol login seed).
#   npm run dev → DEVELOPMENT (tombol seed tampil).
# Opsional paksa tampilan production di dev: VITE_APP_MODE=production
# VITE_APP_MODE=development

